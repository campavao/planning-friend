{
  "type": "APL",
  "version": "2024.3",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "styles": {
    "sectionLabel": {
      "values": [
        {
          "fontSize": "22dp",
          "fontWeight": "700",
          "color": "#94a3b8",
          "letterSpacing": "2dp",
          "paddingBottom": "14dp",
          "paddingTop": "8dp"
        }
      ]
    },
    "ingredientText": {
      "values": [
        {
          "fontSize": "20dp",
          "color": "#e2e8f0",
          "paddingBottom": "8dp",
          "lineHeight": "28dp"
        }
      ]
    },
    "stepText": {
      "values": [
        {
          "fontSize": "20dp",
          "color": "#f1f5f9",
          "paddingBottom": "18dp",
          "lineHeight": "30dp"
        }
      ]
    },
    "stepNumber": {
      "values": [
        {
          "fontSize": "16dp",
          "fontWeight": "700",
          "color": "#60a5fa",
          "letterSpacing": "1dp",
          "paddingBottom": "4dp"
        }
      ]
    }
  },
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "Container",
        "width": "100%",
        "height": "100%",
        "backgroundColor": "#0b1220",
        "direction": "column",
        "items": [
          {
            "type": "AlexaHeader",
            "theme": "dark",
            "headerTitle": "${payload.recipe.title}",
            "headerSubtitle": "${payload.recipe.subtitle}",
            "headerBackgroundColor": "#1e293b",
            "headerDivider": true
          },
          {
            "type": "ScrollView",
            "grow": 1,
            "width": "100%",
            "paddingLeft": "56dp",
            "paddingRight": "56dp",
            "paddingTop": "24dp",
            "paddingBottom": "48dp",
            "item": {
              "type": "Container",
              "direction": "column",
              "items": [
                {
                  "type": "Text",
                  "style": "sectionLabel",
                  "text": "INGREDIENTS",
                  "when": "${payload.recipe.ingredients.length > 0}"
                },
                {
                  "type": "Sequence",
                  "scrollDirection": "vertical",
                  "scrollEnabled": false,
                  "width": "100%",
                  "height": "auto",
                  "shrink": 0,
                  "when": "${payload.recipe.ingredients.length > 0}",
                  "data": "${payload.recipe.ingredients}",
                  "items": [
                    {
                      "type": "Text",
                      "style": "ingredientText",
                      "text": "•   ${data}"
                    }
                  ]
                },
                {
                  "type": "Text",
                  "style": "sectionLabel",
                  "text": "DIRECTIONS",
                  "when": "${payload.recipe.steps.length > 0}"
                },
                {
                  "type": "Sequence",
                  "scrollDirection": "vertical",
                  "scrollEnabled": false,
                  "width": "100%",
                  "height": "auto",
                  "shrink": 0,
                  "when": "${payload.recipe.steps.length > 0}",
                  "data": "${payload.recipe.steps}",
                  "items": [
                    {
                      "type": "Container",
                      "direction": "column",
                      "items": [
                        {
                          "type": "Text",
                          "style": "stepNumber",
                          "text": "STEP ${ordinal}"
                        },
                        {
                          "type": "Text",
                          "style": "stepText",
                          "text": "${data}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    ]
  }
}
