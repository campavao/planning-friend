{
  "type": "APL",
  "version": "2024.3",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "styles": {
    "recipeSectionLabel": {
      "values": [
        {
          "fontSize": "20dp",
          "fontWeight": "700",
          "color": "#94a3b8",
          "letterSpacing": "2dp",
          "paddingBottom": "16dp"
        }
      ]
    },
    "recipeIngredientText": {
      "values": [
        {
          "fontSize": "18dp",
          "color": "#e2e8f0",
          "paddingBottom": "12dp",
          "lineHeight": 1.5
        }
      ]
    },
    "recipeStepText": {
      "values": [
        {
          "fontSize": "22dp",
          "color": "#f1f5f9",
          "lineHeight": 1.5
        }
      ]
    },
    "recipeStepNumber": {
      "values": [
        {
          "fontSize": "14dp",
          "fontWeight": "700",
          "color": "#60a5fa",
          "letterSpacing": "2dp",
          "paddingBottom": "4dp"
        }
      ]
    },
    "recipeEmptyText": {
      "values": [
        {
          "fontSize": "16dp",
          "color": "#64748b",
          "fontStyle": "italic"
        }
      ]
    }
  },
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "Frame",
        "width": "100%",
        "height": "100%",
        "background": "#0b1220",
        "item": {
          "type": "Container",
          "width": "100%",
          "height": "100%",
          "direction": "column",
          "items": [
            {
              "type": "AlexaHeader",
              "theme": "dark",
              "headerTitle": "${payload.recipe.title}",
              "headerSubtitle": "${payload.recipe.subtitle}",
              "headerBackgroundColor": "#1e293b",
              "headerDivider": true
            },
            {
              "type": "Container",
              "direction": "row",
              "width": "100%",
              "grow": 1,
              "items": [
                {
                  "type": "Container",
                  "direction": "column",
                  "width": "66%",
                  "height": "100%",
                  "paddingLeft": "48dp",
                  "paddingRight": "32dp",
                  "paddingTop": "24dp",
                  "items": [
                    {
                      "type": "Text",
                      "style": "recipeSectionLabel",
                      "text": "DIRECTIONS",
                      "when": "${payload.recipe.steps.length > 0}"
                    },
                    {
                      "type": "Sequence",
                      "scrollDirection": "vertical",
                      "width": "100%",
                      "grow": 1,
                      "when": "${payload.recipe.stepItems.length > 0}",
                      "data": "${payload.recipe.stepItems}",
                      "lastItem": [
                        {
                          "type": "Container",
                          "width": "100%",
                          "height": "120dp"
                        }
                      ],
                      "items": [
                        {
                          "type": "Text",
                          "text": "${data.text}",
                          "fontSize": "14dp",
                          "fontWeight": "700",
                          "color": "#60a5fa",
                          "letterSpacing": "2dp",
                          "paddingTop": "14dp",
                          "paddingBottom": "4dp",
                          "width": "100%",
                          "when": "${data.type == 'num'}"
                        },
                        {
                          "type": "Text",
                          "text": "${data.text}",
                          "fontSize": "22dp",
                          "color": "#f1f5f9",
                          "lineHeight": 1.5,
                          "width": "100%",
                          "maxLines": 0,
                          "when": "${data.type == 'body'}"
                        }
                      ]
                    },
                    {
                      "type": "Text",
                      "style": "recipeEmptyText",
                      "text": "No directions saved.",
                      "when": "${payload.recipe.stepItems.length == 0}"
                    }
                  ]
                },
                {
                  "type": "Frame",
                  "width": "34%",
                  "height": "100%",
                  "background": "#0a1018",
                  "item": {
                    "type": "Container",
                    "direction": "column",
                    "width": "100%",
                    "height": "100%",
                    "paddingLeft": "32dp",
                    "paddingRight": "32dp",
                    "paddingTop": "24dp",
                    "items": [
                      {
                        "type": "Text",
                        "style": "recipeSectionLabel",
                        "text": "INGREDIENTS",
                        "when": "${payload.recipe.ingredients.length > 0}"
                      },
                      {
                        "type": "Sequence",
                        "scrollDirection": "vertical",
                        "width": "100%",
                        "grow": 1,
                        "when": "${payload.recipe.ingredients.length > 0}",
                        "data": "${payload.recipe.ingredients}",
                        "lastItem": [
                          {
                            "type": "Container",
                            "width": "100%",
                            "height": "160dp"
                          }
                        ],
                        "items": [
                          {
                            "type": "Text",
                            "text": "•   ${data.body}",
                            "fontSize": "18dp",
                            "color": "#e2e8f0",
                            "lineHeight": 1.5,
                            "paddingBottom": "12dp",
                            "width": "100%",
                            "maxLines": 0
                          }
                        ]
                      },
                      {
                        "type": "Text",
                        "style": "recipeEmptyText",
                        "text": "No ingredients saved.",
                        "when": "${payload.recipe.ingredients.length == 0}"
                      }
                    ]
                  }
                }
              ]
            }
          ]
        }
      }
    ]
  }
}
