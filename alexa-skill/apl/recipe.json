{
  "type": "APL",
  "version": "2024.3",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "styles": {
    "sectionLabel": {
      "values": [
        {
          "fontSize": "20dp",
          "fontWeight": "700",
          "color": "#94a3b8",
          "letterSpacing": "2dp",
          "paddingBottom": "16dp"
        }
      ]
    },
    "ingredientText": {
      "values": [
        {
          "fontSize": "18dp",
          "color": "#e2e8f0",
          "paddingBottom": "10dp",
          "lineHeight": "26dp"
        }
      ]
    },
    "stepText": {
      "values": [
        {
          "fontSize": "22dp",
          "color": "#f1f5f9",
          "paddingBottom": "22dp",
          "lineHeight": "32dp"
        }
      ]
    },
    "stepNumber": {
      "values": [
        {
          "fontSize": "14dp",
          "fontWeight": "700",
          "color": "#60a5fa",
          "letterSpacing": "2dp",
          "paddingBottom": "4dp"
        }
      ]
    },
    "emptyText": {
      "values": [
        {
          "fontSize": "16dp",
          "color": "#64748b",
          "fontStyle": "italic"
        }
      ]
    }
  },
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "Container",
        "width": "100%",
        "height": "100%",
        "backgroundColor": "#0b1220",
        "direction": "column",
        "items": [
          {
            "type": "AlexaHeader",
            "theme": "dark",
            "headerTitle": "${payload.recipe.title}",
            "headerSubtitle": "${payload.recipe.subtitle}",
            "headerBackgroundColor": "#1e293b",
            "headerDivider": true
          },
          {
            "type": "Container",
            "direction": "row",
            "width": "100%",
            "grow": 1,
            "items": [
              {
                "type": "Container",
                "direction": "column",
                "width": "66%",
                "height": "100%",
                "paddingLeft": "48dp",
                "paddingRight": "32dp",
                "paddingTop": "24dp",
                "items": [
                  {
                    "type": "Text",
                    "style": "sectionLabel",
                    "text": "DIRECTIONS",
                    "when": "${payload.recipe.steps.length > 0}"
                  },
                  {
                    "type": "Sequence",
                    "scrollDirection": "vertical",
                    "width": "100%",
                    "grow": 1,
                    "paddingBottom": "24dp",
                    "when": "${payload.recipe.steps.length > 0}",
                    "data": "${payload.recipe.steps}",
                    "items": [
                      {
                        "type": "Container",
                        "direction": "column",
                        "width": "100%",
                        "height": "auto",
                        "shrink": 0,
                        "bind": [
                          {
                            "name": "stepOrdinal",
                            "value": "${ordinal}"
                          },
                          {
                            "name": "stepBody",
                            "value": "${data}"
                          }
                        ],
                        "items": [
                          {
                            "type": "Text",
                            "style": "stepNumber",
                            "text": "STEP ${stepOrdinal}",
                            "width": "100%",
                            "maxLines": 1
                          },
                          {
                            "type": "Text",
                            "style": "stepText",
                            "text": "${stepBody}",
                            "width": "100%",
                            "maxLines": 0,
                            "shrink": 0
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "style": "emptyText",
                    "text": "No directions saved.",
                    "when": "${payload.recipe.steps.length == 0}"
                  }
                ]
              },
              {
                "type": "Container",
                "direction": "column",
                "width": "34%",
                "height": "100%",
                "backgroundColor": "#0a1018",
                "paddingLeft": "32dp",
                "paddingRight": "32dp",
                "paddingTop": "24dp",
                "items": [
                  {
                    "type": "Text",
                    "style": "sectionLabel",
                    "text": "INGREDIENTS",
                    "when": "${payload.recipe.ingredients.length > 0}"
                  },
                  {
                    "type": "Sequence",
                    "scrollDirection": "vertical",
                    "width": "100%",
                    "grow": 1,
                    "paddingBottom": "24dp",
                    "when": "${payload.recipe.ingredients.length > 0}",
                    "data": "${payload.recipe.ingredients}",
                    "items": [
                      {
                        "type": "Container",
                        "direction": "column",
                        "width": "100%",
                        "height": "auto",
                        "shrink": 0,
                        "bind": [
                          {
                            "name": "ingredientBody",
                            "value": "${data}"
                          }
                        ],
                        "items": [
                          {
                            "type": "Text",
                            "style": "ingredientText",
                            "text": "•   ${ingredientBody}",
                            "width": "100%",
                            "maxLines": 0,
                            "shrink": 0
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Text",
                    "style": "emptyText",
                    "text": "No ingredients saved.",
                    "when": "${payload.recipe.ingredients.length == 0}"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
