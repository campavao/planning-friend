{
  "type": "APL",
  "version": "2024.3",
  "import": [
    {
      "name": "alexa-layouts",
      "version": "1.7.0"
    }
  ],
  "theme": "dark",
  "styles": {
    "dayHeader": {
      "values": [
        {
          "fontSize": "26dp",
          "fontWeight": "700",
          "color": "#f1f5f9",
          "paddingBottom": "4dp"
        }
      ]
    },
    "dayHeaderToday": {
      "values": [
        {
          "fontSize": "26dp",
          "fontWeight": "700",
          "color": "#60a5fa",
          "paddingBottom": "4dp"
        }
      ]
    },
    "dayDate": {
      "values": [
        {
          "fontSize": "14dp",
          "color": "#94a3b8",
          "letterSpacing": "1dp",
          "paddingBottom": "20dp"
        }
      ]
    },
    "itemTitle": {
      "values": [
        {
          "fontSize": "20dp",
          "color": "#f1f5f9",
          "lineHeight": "26dp"
        }
      ]
    },
    "itemMeta": {
      "values": [
        {
          "fontSize": "14dp",
          "color": "#94a3b8",
          "paddingTop": "2dp"
        }
      ]
    },
    "emptyText": {
      "values": [
        {
          "fontSize": "16dp",
          "color": "#64748b",
          "fontStyle": "italic"
        }
      ]
    }
  },
  "layouts": {
    "DayCard": {
      "parameters": ["day"],
      "items": [
        {
          "type": "Container",
          "width": "320dp",
          "height": "100%",
          "backgroundColor": "${day.isToday ? '#1e3a8a' : '#1e293b'}",
          "paddingLeft": "24dp",
          "paddingRight": "24dp",
          "paddingTop": "24dp",
          "paddingBottom": "24dp",
          "direction": "column",
          "items": [
            {
              "type": "Text",
              "style": "${day.isToday ? 'dayHeaderToday' : 'dayHeader'}",
              "text": "${day.dayName}"
            },
            {
              "type": "Text",
              "style": "dayDate",
              "text": "${day.shortDate}"
            },
            {
              "type": "Text",
              "style": "emptyText",
              "text": "Nothing planned",
              "when": "${day.items.length == 0}"
            },
            {
              "type": "Sequence",
              "scrollDirection": "vertical",
              "grow": 1,
              "width": "100%",
              "when": "${day.items.length > 0}",
              "data": "${day.items}",
              "items": [
                {
                  "type": "Container",
                  "paddingBottom": "16dp",
                  "direction": "column",
                  "items": [
                    {
                      "type": "Text",
                      "style": "itemTitle",
                      "text": "${data.title}"
                    },
                    {
                      "type": "Text",
                      "style": "itemMeta",
                      "text": "${data.location}",
                      "when": "${data.location}"
                    },
                    {
                      "type": "Text",
                      "style": "itemMeta",
                      "text": "Shared by ${data.sharedBy}",
                      "when": "${data.sharedBy}"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "Container",
        "width": "100%",
        "height": "100%",
        "backgroundColor": "#0b1220",
        "direction": "column",
        "items": [
          {
            "type": "AlexaHeader",
            "theme": "dark",
            "headerTitle": "${payload.week.title}",
            "headerSubtitle": "${payload.week.subtitle}",
            "headerBackgroundColor": "#1e293b",
            "headerDivider": true
          },
          {
            "type": "Sequence",
            "scrollDirection": "horizontal",
            "grow": 1,
            "width": "100%",
            "paddingLeft": "32dp",
            "paddingRight": "32dp",
            "paddingTop": "24dp",
            "paddingBottom": "32dp",
            "data": "${payload.week.days}",
            "numbered": false,
            "items": [
              {
                "type": "Container",
                "paddingRight": "16dp",
                "height": "100%",
                "items": [
                  {
                    "type": "DayCard",
                    "day": "${data}"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
